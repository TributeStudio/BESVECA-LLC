rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownerEmail() {
      return signedIn() && (
        request.auth.token.besvecaAdmin == true ||
        request.auth.token.email in [
          'eric@tribute.studio',
          'jessica@tribute.studio'
        ]
      );
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function businessMember(businessId) {
      return signedIn() &&
        businessId == 'besveca-house' &&
        (
          ownerEmail() ||
          exists(/databases/$(database)/documents/businesses/$(businessId)/members/$(request.auth.token.email))
        );
    }

    match /businesses/{businessId} {
      allow read: if businessMember(businessId);
      allow create, update, delete: if ownerEmail();

      match /members/{memberId} {
        allow read: if businessMember(businessId);
        allow create, update, delete: if ownerEmail();
      }

      match /projects/{projectId} {
        allow read, write: if businessMember(businessId);
      }

      match /logs/{logId} {
        allow read, write: if businessMember(businessId);
      }

      match /invoices/{invoiceId} {
        allow read, write: if businessMember(businessId);
      }

      match /backups/{backupId} {
        allow read, write: if businessMember(businessId);
      }
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || ownerEmail();
    }

    match /users_metadata/{metadataId} {
      allow read: if signedIn();
      allow create, update, delete: if ownerEmail();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
